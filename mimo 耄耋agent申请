require('sqlite-vec');
const { openai } = require('./ai');

// 向量搜索知识点
async function searchKnowledge(query, language) {
  // 生成query向量
  const embedding = await openai.embeddings.create({
    model: 'text-embedding-3-small',
    input: query
  });
  const queryVector = embedding.data[0].embedding;

  const db = await open({
    filename: './knowledge.db',
    driver: sqlite3.Database
  });
  
  // sqlite-vec做余弦相似度搜索
  const rows = await db.all(`
    SELECT id, title, content, language
    FROM knowledge
    ORDER BY vec_distance_cosine(embedding, ?) ASC
    LIMIT 5
  `, Buffer.from(new Float32Array(queryVector).buffer));

  await db.close();
  return rows.filter(r => r.language === language || r.language === 'all');
}

module.exports = { searchKnowledge };
