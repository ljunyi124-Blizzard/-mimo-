import { useState, useRef } from 'react';
import * as monaco from 'monaco-editor';
import { MonacoEditor } from '@monaco-editor/react';
import './index.css';

function App() {
  const [language, setLanguage] = useState('cpp');
  const [output, setOutput] = useState('');
  const [userQuestion, setUserQuestion] = useState('');
  const [chatHistory, setChatHistory] = useState([]);
  const editorRef = useRef(null);

  // 调用后端Agent接口获取引导提问
  const askAgent = async () => {
    try {
      const res = await fetch('http://localhost:3000/api/ask', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          question: userQuestion,
          language,
          history: chatHistory
        })
      });
      const data = await res.json();
      setChatHistory([...chatHistory, {role: 'user', content: userQuestion}, {role: 'agent', content: data.reply}]);
      setUserQuestion('');
    } catch (err) {
      setOutput(`AI请求失败: ${err.message}`);
    }
  };

  // 调用代码执行接口
  const runCode = async () => {
    const code = editorRef.current?.getValue();
    setOutput('正在运行...');
    try {
      const res = await fetch('http://localhost:8000/api/run', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ language, code })
      });
      const data = await res.json();
      setOutput(data.success ? `✅ 运行成功\n${data.output}` : `❌ 运行失败\n${data.error}`);
    } catch (err) {
      setOutput(`请求失败: ${err.message}`);
    }
  };

  return (
    <div className="min-h-screen bg-gray-100 p-4">
      <h1 className="text-2xl font-bold mb-4 text-gray-800">智能编程助教</h1>
      
      <div className="grid grid-cols-1 lg:grid-cols-3 gap-4">
        {/* 左侧：对话区 */}
        <div className="lg:col-span-1 bg-white rounded-lg shadow p-4 h-[80vh] flex flex-col">
          <h2 className="font-semibold mb-2">答疑引导</h2>
          <div className="flex-1 overflow-y-auto mb-4 border rounded p-2">
            {chatHistory.map((item, idx) => (
              <div key={idx} className={`mb-3 p-2 rounded ${item.role === 'user' ? 'bg-blue-100 ml-4' : 'bg-gray-100 mr-4'}`}>
                {item.content}
              </div>
            ))}
          </div>
          <div className="flex gap-2">
            <input
              className="flex-1 border rounded px-3 py-2"
              placeholder="输入你的问题..."
              value={userQuestion}
              onChange={e => setUserQuestion(e.target.value)}
            />
            <button className="bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" onClick={askAgent}>提问</button>
          </div>
        </div>

        {/* 右侧：代码编辑+输出 */}
        <div className="lg:col-span-2 flex flex-col gap-4">
          {/* 代码编辑器 */}
          <div className="bg-white rounded-lg shadow p-4">
            <div className="flex justify-between items-center mb-2">
              <h2 className="font-semibold">代码编辑器</h2>
              <div className="flex gap-2">
                <select
                  className="border rounded px-2 py-1"
                  value={language}
                  onChange={e => setLanguage(e.target.value)}
                >
                  <option value="cpp">C++</option>
                  <option value="python">Python</option>
                </select>
                <button className="bg-green-500 text-white px-4 py-1 rounded hover:bg-green-600" onClick={runCode}>运行代码</button>
              </div>
            </div>
            <MonacoEditor
              height="50vh"
              language={language}
              defaultValue={`// 在这里写下你的${language}代码`}
              onMount={editor => editorRef.current = editor}
            />
          </div>
          
          {/* 运行输出 */}
          <div className="bg-black text-white rounded-lg shadow p-4 h-[20vh] overflow-y-auto">
            <pre>{output}</pre>
          </div>
        </div>
      </div>
    </div>
  );
}

export default App;
