// 初始化数据库
async function initDB() {
  const db = await open({
    filename: './user_memory.db',
    driver: sqlite3.Database
  });
  await db.exec(`
    CREATE TABLE IF NOT EXISTS history (
      id INTEGER PRIMARY KEY AUTOINCREMENT,
      question TEXT,
      response TEXT,
      knowledge_ids TEXT,
      created_at DATETIME DEFAULT CURRENT_TIMESTAMP
    )
  `);
  return db;
}

async function getHistory() {
  const db = await initDB();
  const rows = await db.all('SELECT * FROM history ORDER BY created_at DESC LIMIT 20');
  await db.close();
  return rows;
}

async function updateHistory({question, response, knowledge}) {
  const db = await initDB();
  await db.run(
    'INSERT INTO history (question, response, knowledge_ids) VALUES (?, ?, ?)',
    [question, response, JSON.stringify(knowledge.map(k => k.id))]
  );
  await db.close();
}

module.exports = { getHistory, updateHistory };
