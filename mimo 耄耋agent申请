const { Hono } = require('hono');
const { serve } = require('@hono/node-server');
const cors = require('cors');
const { openai } = require('./ai');
const { searchKnowledge } = require('./knowledge');
const { getHistory, updateHistory } = require('./memory');

const app = new Hono();
app.use('*', async (c, next) => {
  c.header('Access-Control-Allow-Origin', '*');
  c.header('Access-Control-Allow-Methods', 'POST, GET, OPTIONS');
  c.header('Access-Control-Allow-Headers', 'Content-Type');
  if (c.req.method === 'OPTIONS') {
    return c.newResponse(null, 204);
  }
  await next();
});

// 核心提问接口
app.post('/api/ask', async (c) => {
  const { question, language, history } = await c.req.json();
  
  // 1. 检索用户记忆和历史交互
  const userHistory = await getHistory();
  // 2. 基于问题检索知识图谱知识点
  const relatedKnowledge = await searchKnowledge(question, language);
  // 3. 构造苏格拉底式提示词，调用Agent
  const prompt = `
你是一个面向C++/Python初学者的编程助教，你必须采用苏格拉底式提问法，不直接给出答案，通过递进式提问引导用户独立思考找到问题。
用户当前问题是：${question}
相关知识点参考：${JSON.stringify(relatedKnowledge)}
用户历史交互：${JSON.stringify(userHistory)}
请输出你的引导问题。
  `;
  const reply = await openai.chat.completions.create({
    model: 'gpt-3.5-turbo',
    messages: [{role: 'user', content: prompt}],
    temperature: 0.7
  });
  const responseText = reply.choices[0].message.content;
  
  // 4. 更新用户记忆
  await updateHistory({question, response: responseText, knowledge: relatedKnowledge});
  
  return c.json({reply: responseText});
});

