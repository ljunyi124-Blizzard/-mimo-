from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
import subprocess
import tempfile
import os
from fastapi.middleware.cors import CORSMiddleware

app = FastAPI()

app.add_middleware(
    CORSMiddleware,
    allow_origins=["*"],
    allow_credentials=True,
    allow_methods=["*"],
    allow_headers=["*"],
)

class CodeRunRequest(BaseModel):
    language: str
    code: str

@app.post("/api/run")
def run_code(req: CodeRunRequest):
    if req.language == "python":
        try:
            res = subprocess.run(
                ["python", "-c", req.code],
                capture_output=True,
                text=True,
                timeout=10
            )
            return {
                "output": res.stdout,
                "error": res.stderr,
                "success": res.returncode == 0
            }
        except Exception as e:
            return {"output": "", "error": str(e), "success": False}
    
    elif req.language == "cpp":
        with tempfile.NamedTemporaryFile(mode='w', suffix='.cpp', delete=False) as f:
            f.write(req.code)
            tmp_file = f.name
        try:
            # 编译
            compile_res = subprocess.run(
                ["g++", tmp_file, "-o", tmp_file + ".out"],
                capture_output=True,
                text=True
            )
            if compile_res.returncode != 0:
                return {"output": "", "error": compile_res.stderr, "success": False}
            # 运行
            run_res = subprocess.run(
                [tmp_file + ".out"],
                capture_output=True,
                text=True,
                timeout=10
            )
            return {
                "output": run_res.stdout,
                "error": run_res.stderr,
                "success": run_res.returncode == 0
            }
        finally:
            os.unlink(tmp_file)
            if os.path.exists(tmp_file + ".out"):
                os.unlink(tmp_file + ".out")
    
    else:
        raise HTTPException(status_code=400, detail="不支持的语言")

if __name__ == "__main__":
    import uvicorn
    uvicorn.run(app, host="0.0.0.0", port=8000)
